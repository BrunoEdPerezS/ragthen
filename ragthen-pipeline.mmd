%%{init: {"theme": "base", "themeVariables": {"primaryColor": "#e8edf2", "primaryTextColor": "#1e293b", "primaryBorderColor": "#94a3b8", "lineColor": "#64748b", "secondaryColor": "#f1f5f9", "tertiaryColor": "#f8fafc", "edgeLabelBackground": "#ffffff", "clusterBkg": "#f8fafc", "clusterBorder": "#cbd5e1", "titleColor": "#334155"}}}%%
graph TB
    subgraph INGESTA["INGESTA: ragthen ingest -l NAME"]
        direction TB
        A["Archivos en libreria<br/>~/.ragthen/libraries/NAME/"] --> B["File Discovery<br/>glob: *.pdf, *.epub, *.txt, *.md"]
        B --> C{"Router por extension"}
        C -->|".pdf"| D["PyMuPDF (fitz)<br/>page.get_text()<br/><br/>Sin OCR: escaneados producen 0 chunks<br/>Encoding corrupto: acentos se pierden<br/>Sin layout: tablas y columnas mezcladas<br/>Headers y footers no filtrados"]
        C -->|".epub"| E["ebooklib + markdownify<br/>XHTML a Markdown<br/>MathML a LaTeX<br/>Deteccion de DRM"]
        C -->|".txt .md"| F["Lectura directa<br/>Sin procesamiento"]
        D --> G["Chunking CIEGO (PDF/TXT)<br/>Ventana deslizante: 1200 caracteres<br/>Overlap: 250 caracteres<br/>Stride: 950 caracteres<br/><br/>Corta palabras a la mitad<br/>No respeta oraciones ni parrafos<br/>No cruza paginas"]
        E --> H["Chunking HEADING-AWARE (EPUB/MD)<br/>Regex de headings H1-H6<br/>Respeta secciones del documento<br/>Sub-chunking si excede chunk_size"]
        F --> G
        G --> I["Embedding Fijo<br/>SentenceTransformer<br/>all-MiniLM-L6-v2<br/>384 dimensiones, max 256 tokens<br/><br/>Trunca chunks largos silenciosamente"]
        H --> I
        I --> J["ChromaDB<br/>PersistentClient<br/>Coleccion: cosine distance<br/>Batch: 200 chunks por add()"]
    end

    subgraph BUSQUEDA["BUSQUEDA: ragthen search -l NAME"]
        direction TB
        Q["Query del usuario"] --> QE["Embedding<br/>all-MiniLM-L6-v2"]
        QE --> QS["ChromaDB query<br/>top_k multiplicado por 3"]
        QS --> QR["Cross-encoder Reranker<br/>ms-marco-MiniLM-L-6-v2<br/>Sigmoid score: 0 a 1"]
        QR --> QT["JSON output<br/>{source, page, relevance, text}"]
    end

    subgraph RAG["RAG ANSWER: ragthen ask -l NAME"]
        direction TB
        RA["Query del usuario"] --> RS["Search interno"]
        RS --> RP["Prompt template<br/>System: bibliotecario<br/>Context: top N chunks"]
        RP --> RL["OpenAI gpt-4o<br/>Sintetiza respuesta<br/>Citas: [Source, Page X]"]
    end

    J -.-> QS
    J -.-> RS

    style D fill:#ffcccc,stroke:#cc0000
    style G fill:#ffcccc,stroke:#cc0000
    style I fill:#fff3cd,stroke:#cc9900

    style INGESTA fill:#fef7ed,stroke:#d4a373,color:#5c4a3a
    style BUSQUEDA fill:#eff6ff,stroke:#93c5fd,color:#1e3a5f
    style RAG fill:#f0fdf4,stroke:#86efac,color:#14532d
